# Project root .gitignore
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.so.*
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out
.coverage

# Dependency directories
vendor/
bin/

# Go workspace file
go.work

# IDEs
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Environment variables
.env
.env.local
.env.*.local

# Logs
*.log

# Database files
*.db
*.sqlite

# Build output
/dist/
/build/

# Air (live reload)
tmp/
