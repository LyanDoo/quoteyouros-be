              "host": ["{{base_url}}"],
              "path": ["api", "blog", "{{blog_id}}"]
            },
            "description": "Fetch a specific blog post"
          },
          "response": []
        },
        {
          "name": "Create Blog Post",
          "request": {
            "method": "POST",
            "header": [
