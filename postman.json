              "host": ["{{base_url}}"],
              "path": ["api", "blog", "{{blog_id}}"]
            },
            "description": "Update an existing blog post (protected)"
          },
          "response": []
        },
        {
          "name": "Delete Blog Post",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/blog/{{blog_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "blog", "{{blog_id}}"]
            },
            "description": "Delete a blog post (protected)"
