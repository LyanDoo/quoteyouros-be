                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My First Blog Post\",\n  \"date\": \"2026-05-20T15:47:00Z\",\n  \"excerpt\": \"This is a brief excerpt of the blog post\",\n  \"content\": \"This is the full content of the blog post with detailed information\"\n}"
            },
            "url": {
